# ===========================
# Root-level .gitignore
# ===========================

# Environment variables — NEVER commit secrets
**/.env
**/.env.local
**/.env.*.local

# Python
**/__pycache__/
**/*.py[cod]
**/venv/
**/env/
**/.venv/

# Node
**/node_modules/

# Build output
**/dist/
**/dist-ssr/

# SQLite databases
**/*.db
**/*.sqlite3

# Logs
**/*.log

# OS/Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
